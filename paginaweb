    });
    $("demoBtn").addEventListener("click", () => {
      $("contractText").value = demoText;
      $("purposeText").value = demoPurpose;
      analyze();
    });
    $("analyzeBtn").addEventListener("click", analyze);
    $("questionBtn").addEventListener("click", ask);
    $("spijBtn").addEventListener("click", updateSpij);

    async function analyze() {
      const form = new FormData();
      const file = $("contractFile").files[0];
      if (file) form.append("file", file);
      form.append("contractText", $("contractText").value);
      form.append("purpose", $("purposeText").value);
      showLoading("Analizando con fuentes locales...");
      const data = await post("/api/analyze", form);
      renderFindings(data.findings || []);
    }

    async function ask() {
      const form = new FormData();
      form.append("question", $("questionText").value);
      showLoading("Buscando respaldo en la base...");
      const data = await post("/api/question", form);
      renderAnswer(data);
    }

    async function updateSpij() {
      const form = new FormData();
      form.append("urls", $("spijUrls").value);
      showLoading("Revisando enlaces SPIJ...");
      const data = await post("/api/update-spij", form);
      renderSpij(data.results || []);
    }

    async function post(url, form) {
      const response = await fetch(url, { method: "POST", body: form });
      if (!response.ok) throw new Error(await response.text());
      return response.json();
    }

    function showLoading(text) {
      results.innerHTML = `<div class="finding"><h3>${escapeHtml(text)}</h3><p>Un momento.</p></div>`;
    }

    function renderFindings(findings) {
      results.innerHTML = findings.map(item => `
        <article class="finding ${item.level}">
          <h3>${escapeHtml(item.title)} <span class="tag">${escapeHtml(item.level)}</span></h3>
          <p>${escapeHtml(item.detail)}</p>
          ${renderCitations(item.citations || [])}
        </article>
      `).join("") || `<div class="finding"><h3>Sin resultados</h3><p>No se encontró texto suficiente para analizar.</p></div>`;
    }

    function renderAnswer(data) {
      results.innerHTML = `
        <article class="finding">
          <h3>Respuesta con fuentes</h3>
          <p>${escapeHtml(data.answer || "")}</p>
          ${renderCitations(data.citations || [])}
        </article>
      `;
    }

    function renderSpij(items) {
      results.innerHTML = items.map(item => `
        <article class="finding ${item.ok ? "bajo" : "alto"}">
          <h3>${item.ok ? (item.changed ? "Fuente actualizada" : "Sin cambios") : "No se pudo revisar"}</h3>
          <p>${escapeHtml(item.url || "")}</p>
          <p>${item.ok ? `Texto guardado: ${item.chars} caracteres.` : escapeHtml(item.error || "")}</p>
        </article>
      `).join("") || `<div class="finding"><h3>Agrega enlaces</h3><p>Pega uno o más enlaces del SPIJ para revisarlos.</p></div>`;
    }

    function renderCitations(citations) {
      if (!citations.length) return `<div class="citation"><b>Fuente:</b> no se encontró cita suficiente.</div>`;
      return citations.map(c => `
        <div class="citation">
          <b>${escapeHtml(c.source)}${c.page ? " - pág. " + escapeHtml(String(c.page)) : ""}</b>
          ${c.url ? `<br><a href="${escapeHtml(c.url)}" target="_blank" rel="noreferrer">${escapeHtml(c.url)}</a>` : ""}
          <br>${escapeHtml(c.text)}
        </div>
      `).join("");
    }

    function escapeHtml(value) {
      return String(value).replace(/[&<>"']/g, ch => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[ch]));
    }
  </script>
</body>
</html>"""


class LexCheckHandler(BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path in {"/", "/index.html"}:
            self.reply(200, HTML.encode("utf-8"), "text/html; charset=utf-8")
            return
        self.reply(404, b"No encontrado", "text/plain; charset=utf-8")

    def do_POST(self):
        try:
            form = cgi.FieldStorage(fp=self.rfile, headers=self.headers, environ={
                "REQUEST_METHOD": "POST",
                "CONTENT_TYPE": self.headers.get("Content-Type"),
            })
            if self.path == "/api/analyze":
                contract_text = form.getfirst("contractText", "")
                purpose = form.getfirst("purpose", "")
                if "file" in form and getattr(form["file"], "filename", ""):
                    file_item = form["file"]
                    contract_text += "\n" + read_upload(file_item.filename, file_item.file.read())
                findings = analyze_contract(contract_text, purpose) if compact_text(contract_text) else []
                self.json({"findings": findings})
                return
            if self.path == "/api/question":
                self.json(answer_question(form.getfirst("question", "")))
                return
            if self.path == "/api/update-spij":
                urls = form.getfirst("urls", "").splitlines()
                self.json({"results": update_spij_sources(urls)})
                return
            self.reply(404, b"No encontrado", "text/plain; charset=utf-8")
        except Exception as exc:
            self.reply(500, str(exc).encode("utf-8"), "text/plain; charset=utf-8")

    def json(self, data):
        self.reply(200, json.dumps(data, ensure_ascii=False).encode("utf-8"), "application/json; charset=utf-8")

    def reply(self, status, body, content_type):
        self.send_response(status)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def log_message(self, *_):
        return


